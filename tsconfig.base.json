{
  "compilerOptions": {
    "esModuleInterop": true,
    "module": "es2022",
    "moduleResolution": "bundler",
    "target": "es2021",
    "lib": ["es2022", "es2021", "dom"],
    "strict": false,
    "skipLibCheck": true,
    "types": ["vite/client"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "***/test/**", "**/*.test.ts"]
}