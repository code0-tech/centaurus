{
  "name": "centaurus",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "actions/*"
  ],
  "packageManager": "npm@11.12.1",
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "generate:docs": "npm run generate:docs --workspaces --if-present",
    "start": "turbo run start",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "create-action": "node scripts/create-action.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "eslint": "^10.0.0",
    "globals": "^17.4.0",
    "turbo": "^2.8.21",
    "typescript": "^5",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.0.0"
  },
  "dependencies": {
    "@code0-tech/hercules": "^0.0.2",
    "axios": "^1.13.6",
    "vite": "^7.3.1",
    "zod": "^4.3.6",
    "zod-to-ts": "^2.0.0"
  }
}
